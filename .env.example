# ---- Idea Wall Antarestar — environment ----
# Copy this file to `.env` and fill in your own values.

# Port the server listens on (default 3030)
PORT=3030

# Admin panel password (used at /admin). CHANGE THIS.
ADMIN_PASSWORD=change-me-admin

# ---- Google OAuth (OPTIONAL) ----
# Leave blank to disable "Sign in with Google" — username/password login still works.
# Create credentials at https://console.cloud.google.com/apis/credentials
# and set the callback URL below as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT=http://localhost:3030/auth/google/callback
